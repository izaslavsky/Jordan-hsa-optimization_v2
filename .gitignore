# ── Publication data rules ────────────────────────────────────────────────────
# Only SYNMOD* files belong in this repo.
# Real patient data (INF_* and NCD_* without SYNMOD prefix) must never be committed.
data/INF_*
data/NCD_*
data/SYNMOD_generation_report.json

# Generated outputs — populated at runtime, not tracked
out/
!out/.gitkeep

# Misc artefacts
*.zip
*.xlsx
